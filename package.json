{
  "name": "hapics-news",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "validate:data": "node scripts/validate-data.mjs",
    "publish:edition": "node scripts/publish-edition.mjs",
    "build": "npm run validate:data && tsc -b && vite build",
    "preview": "vite preview",
    "test": "npm run validate:data && tsc -b --pretty false"
  },
  "dependencies": {
    "@fontsource/inter": "latest",
    "@fontsource/newsreader": "latest",
    "@radix-ui/react-select": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "ajv": "latest",
    "ajv-formats": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-static-copy": "latest"
  }
}
