{
  "name": "hapics-news",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "validate:data": "node scripts/validate-data.mjs",
    "fetch:indicators": "node scripts/fetch-indicators.mjs",
    "publish:edition": "node scripts/publish-edition.mjs",
    "build": "npm run validate:data && tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist-ssr && node prerender.mjs",
    "preview": "vite preview",
    "test": "npm run validate:data && tsc -b --pretty false"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@radix-ui/react-select": "^2.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
